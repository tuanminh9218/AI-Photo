rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 200 && id.matches('^[a-zA-Z0-9_\\-,.\\s]+$');
    }

    function isValidPreviewAsset(data, assetId) {
      return data.url is string && data.url.size() < 1000000
        && data.key == assetId
        && data.gender in ['Nam', 'Nữ']
        && (data.intensity is number || data.intensity is int)
        && data.types is list && data.types.size() <= 10
        && data.style is string
        && data.bg is string
        && data.lighting is string
        && data.createdAt == request.time;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User usage tracking
    match /user_usage/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.totalGenerations is int;
      allow update: if isOwner(userId) 
        && request.resource.data.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastGenerationAt', 'totalGenerations']);
    }

    // Global Preview Assets Cache
    match /preview_assets/{assetId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidId(assetId)
        && isValidPreviewAsset(request.resource.data, assetId);
    }
  }
}
